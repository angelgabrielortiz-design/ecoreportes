<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EcoReportes — Panel Municipal</title>
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;800&display=swap" rel="stylesheet"/>
<style>
  :root {
    --verde: #1a5c3a;
    --verde-claro: #2d8a57;
    --acento: #c8f04a;
    --fondo: #0d1f14;
    --fondo2: #132a1a;
    --texto: #e8f5e0;
    --texto2: #8fbb7a;
    --baja: #4ac8f0;
    --media: #f0c84a;
    --alta: #f04a4a;
    --borde: #2a4a32;
    --pendiente: #f0c84a;
    --terminado: #4ac87a;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body { font-family:'Syne',sans-serif; background:var(--fondo); color:var(--texto); height:100vh; display:flex; flex-direction:column; overflow:hidden; }

  header { background:var(--fondo2); border-bottom:1px solid var(--borde); padding:0 24px; height:60px; display:flex; align-items:center; justify-content:space-between; flex-shrink:0; z-index:1000; }
  .logo { display:flex; align-items:center; gap:10px; }
  .logo-icon { width:32px; height:32px; background:var(--acento); border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:16px; }
  .logo-text { font-size:18px; font-weight:800; color:var(--texto); letter-spacing:-0.5px; }
  .logo-text span { color:var(--acento); }
  .header-right { display:flex; align-items:center; gap:16px; }
  .badge { font-family:'Space Mono',monospace; font-size:11px; background:var(--verde); color:var(--acento); padding:4px 10px; border-radius:4px; border:1px solid var(--acento); letter-spacing:1px; }
  #btn-actualizar { font-family:'Syne',sans-serif; font-size:13px; font-weight:600; background:var(--acento); color:var(--fondo); border:none; padding:8px 16px; border-radius:6px; cursor:pointer; transition:opacity 0.2s; }
  #btn-actualizar:hover { opacity:0.85; }

  .main { display:flex; flex:1; overflow:hidden; }

  .sidebar { width:340px; background:var(--fondo2); border-right:1px solid var(--borde); display:flex; flex-direction:column; flex-shrink:0; overflow:hidden; }
  .sidebar-header { padding:16px 20px; border-bottom:1px solid var(--borde); }
  .sidebar-title { font-size:13px; font-weight:600; color:var(--texto2); text-transform:uppercase; letter-spacing:1.5px; margin-bottom:12px; }
  .stats { display:grid; grid-template-columns:1fr 1fr 1fr 1fr; gap:6px; }
  .stat { background:var(--fondo); border-radius:8px; padding:8px; text-align:center; border:1px solid var(--borde); }
  .stat-num { font-family:'Space Mono',monospace; font-size:20px; font-weight:700; line-height:1; }
  .stat-label { font-size:9px; color:var(--texto2); margin-top:4px; text-transform:uppercase; letter-spacing:0.5px; }
  .stat.alta .stat-num { color:var(--alta); }
  .stat.media .stat-num { color:var(--media); }
  .stat.baja .stat-num { color:var(--baja); }
  .stat.terminado .stat-num { color:var(--terminado); }

  .filtros { padding:10px 20px; border-bottom:1px solid var(--borde); display:flex; gap:6px; flex-wrap:wrap; }
  .filtro-btn { font-family:'Space Mono',monospace; font-size:10px; padding:5px 10px; border-radius:4px; border:1px solid var(--borde); background:transparent; color:var(--texto2); cursor:pointer; transition:all 0.15s; letter-spacing:0.5px; }
  .filtro-btn.active, .filtro-btn:hover { background:var(--verde); color:var(--acento); border-color:var(--acento); }

  .lista-reportes { flex:1; overflow-y:auto; padding:8px; }
  .lista-reportes::-webkit-scrollbar { width:4px; }
  .lista-reportes::-webkit-scrollbar-track { background:transparent; }
  .lista-reportes::-webkit-scrollbar-thumb { background:var(--borde); border-radius:2px; }

  .reporte-card { background:var(--fondo); border:1px solid var(--borde); border-radius:8px; padding:12px; margin-bottom:6px; cursor:pointer; transition:all 0.15s; border-left:3px solid transparent; }
  .reporte-card:hover { border-color:var(--verde-claro); transform:translateX(2px); }
  .reporte-card.alta { border-left-color:var(--alta); }
  .reporte-card.media { border-left-color:var(--media); }
  .reporte-card.baja { border-left-color:var(--baja); }
  .reporte-card.terminado { opacity:0.6; }

  .card-top { display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:4px; gap:6px; }
  .card-tipo { font-size:12px; font-weight:600; color:var(--texto); flex:1; }
  .card-badges { display:flex; gap:4px; flex-wrap:wrap; justify-content:flex-end; }
  .card-prioridad { font-family:'Space Mono',monospace; font-size:9px; padding:2px 6px; border-radius:3px; text-transform:uppercase; letter-spacing:0.5px; }
  .card-prioridad.alta { background:rgba(240,74,74,0.15); color:var(--alta); }
  .card-prioridad.media { background:rgba(240,200,74,0.15); color:var(--media); }
  .card-prioridad.baja { background:rgba(74,200,240,0.15); color:var(--baja); }
  .card-estado { font-family:'Space Mono',monospace; font-size:9px; padding:2px 6px; border-radius:3px; text-transform:uppercase; letter-spacing:0.5px; }
  .card-estado.pendiente { background:rgba(240,200,74,0.15); color:var(--pendiente); }
  .card-estado.terminado { background:rgba(74,200,122,0.15); color:var(--terminado); }

  .card-desc { font-size:11px; color:var(--texto2); line-height:1.4; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; margin-bottom:6px; }
  .card-coords { font-family:'Space Mono',monospace; font-size:9px; color:var(--verde-claro); margin-bottom:8px; }
  .card-actions { display:flex; gap:6px; }

  .btn-resolver { font-family:'Syne',sans-serif; font-size:11px; font-weight:600; padding:5px 10px; border-radius:5px; border:none; cursor:pointer; transition:all 0.2s; }
  .btn-pendiente { background:rgba(240,200,74,0.2); color:var(--media); border:1px solid var(--media); }
  .btn-pendiente:hover { background:var(--media); color:var(--fondo); }
  .btn-terminado-act { background:rgba(74,200,122,0.2); color:var(--terminado); border:1px solid var(--terminado); }
  .btn-terminado-act:hover { background:var(--terminado); color:var(--fondo); }
  .btn-ver { font-family:'Syne',sans-serif; font-size:11px; padding:5px 10px; border-radius:5px; border:1px solid var(--borde); background:transparent; color:var(--texto2); cursor:pointer; }
  .btn-ver:hover { border-color:var(--acento); color:var(--acento); }

  #map { flex:1; background:var(--fondo); }
  .leaflet-container { background:#0d1f14 !important; }
  .leaflet-popup-content-wrapper { background:var(--fondo2) !important; border:1px solid var(--borde) !important; border-radius:10px !important; color:var(--texto) !important; box-shadow:0 8px 32px rgba(0,0,0,0.5) !important; min-width:220px; }
  .leaflet-popup-tip { background:var(--fondo2) !important; }
  .popup-tipo { font-size:14px; font-weight:700; margin-bottom:8px; color:var(--acento); }
  .popup-row { font-size:12px; margin-bottom:4px; color:var(--texto2); }
  .popup-row strong { color:var(--texto); }
  .popup-badges { display:flex; gap:6px; margin:8px 0; }
  .popup-badge { font-family:'Space Mono',monospace; font-size:10px; padding:3px 8px; border-radius:4px; text-transform:uppercase; }
  .popup-actions { margin-top:10px; display:flex; gap:6px; }
  .popup-btn { font-family:'Syne',sans-serif; font-size:12px; font-weight:600; padding:6px 12px; border-radius:6px; border:none; cursor:pointer; flex:1; transition:all 0.2s; }

  #loading { position:fixed; inset:0; background:var(--fondo); display:flex; flex-direction:column; align-items:center; justify-content:center; z-index:9999; gap:16px; }
  .spinner { width:40px; height:40px; border:3px solid var(--borde); border-top-color:var(--acento); border-radius:50%; animation:spin 0.8s linear infinite; }
  @keyframes spin { to { transform:rotate(360deg); } }
  #loading p { font-family:'Space Mono',monospace; font-size:12px; color:var(--texto2); letter-spacing:1px; }

  .toast { position:fixed; bottom:24px; right:24px; background:var(--fondo2); border:1px solid var(--acento); color:var(--acento); font-family:'Space Mono',monospace; font-size:12px; padding:12px 20px; border-radius:8px; z-index:9998; transform:translateY(80px); opacity:0; transition:all 0.3s; }
  .toast.show { transform:translateY(0); opacity:1; }
</style>
</head>
<body>

<div id="loading"><div class="spinner"></div><p>CARGANDO REPORTES...</p></div>
<div class="toast" id="toast"></div>

<header>
  <div class="logo">
    <div class="logo-icon">🌿</div>
    <div class="logo-text">Eco<span>Reportes</span></div>
  </div>
  <div class="header-right">
    <span class="badge">PANEL MUNICIPAL</span>
    <button id="btn-actualizar" onclick="cargarDatos()">↻ Actualizar</button>
  </div>
</header>

<div class="main">
  <div class="sidebar">
    <div class="sidebar-header">
      <div class="sidebar-title">Resumen</div>
      <div class="stats">
        <div class="stat alta"><div class="stat-num" id="cnt-alta">0</div><div class="stat-label">Alta</div></div>
        <div class="stat media"><div class="stat-num" id="cnt-media">0</div><div class="stat-label">Media</div></div>
        <div class="stat baja"><div class="stat-num" id="cnt-baja">0</div><div class="stat-label">Baja</div></div>
        <div class="stat terminado"><div class="stat-num" id="cnt-terminado">0</div><div class="stat-label">Resueltos</div></div>
      </div>
    </div>
    <div class="filtros">
      <button class="filtro-btn active" onclick="filtrar('todos',this)">Todos</button>
      <button class="filtro-btn" onclick="filtrar('pendiente',this)">Pendientes</button>
      <button class="filtro-btn" onclick="filtrar('terminado',this)">Resueltos</button>
      <button class="filtro-btn" onclick="filtrar('Alta',this)">🔴 Alta</button>
    </div>
    <div class="lista-reportes" id="lista"></div>
  </div>
  <div id="map"></div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const SHEET_ID = '17ZAvOQE2Vw7sf4OSI9C59fYcx8hdU1-k_s7sBLpVjtg';
const APPS_SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxsizn43ORkgHL73XBwCs7hiq9tS_pi-2hVMwWUBFzUQEG_QVQfMARxmnU76bngzOMH/exec';
const URL_CSV = `https://docs.google.com/spreadsheets/d/${SHEET_ID}/gviz/tq?tqx=out:csv&sheet=Hoja1`;

let mapa, reportes=[], markers=[], filtroActual='todos';

mapa = L.map('map',{zoomControl:false}).setView([20.5,-100.5],10);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{attribution:'© OpenStreetMap © CARTO',subdomains:'abcd',maxZoom:19}).addTo(mapa);
L.control.zoom({position:'bottomright'}).addTo(mapa);

function getPrioridad(p){
  if(!p) return 'baja';
  p=p.toLowerCase();
  if(p.includes('alta')) return 'alta';
  if(p.includes('media')) return 'media';
  return 'baja';
}

function getColor(p){
  if(p==='alta') return '#f04a4a';
  if(p==='media') return '#f0c84a';
  return '#4ac8f0';
}

function getEstado(r){ return (r.estado||'').toLowerCase().includes('terminado') ? 'terminado' : 'pendiente'; }

function crearIcono(prioridad, estado){
  const color = estado==='terminado' ? '#4ac87a' : getColor(prioridad);
  const size = estado==='terminado' ? 10 : 14;
  return L.divIcon({
    html:`<div style="width:${size}px;height:${size}px;background:${color};border:2px solid white;border-radius:50%;box-shadow:0 0 8px ${color}88;"></div>`,
    className:'', iconSize:[size,size], iconAnchor:[size/2,size/2]
  });
}

function mostrarToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),3000);
}

async function cambiarEstado(fecha, nuevoEstado, idx){
  try {
    await fetch(APPS_SCRIPT_URL, {
      method:'POST',
      mode:'no-cors',
      headers:{'Content-Type':'application/json'},
      body:JSON.stringify({fecha:String(fecha), estado:nuevoEstado})
    });
    reportes[idx].estado = nuevoEstado;
    mostrarToast(nuevoEstado==='Terminado' ? '✓ Marcado como resuelto' : '↻ Marcado como pendiente');
    actualizarStats(reportes);
    aplicarFiltro();
  } catch(e) {
    mostrarToast('Error al actualizar');
  }
}

function parsearCSV(texto){
  const lineas=texto.trim().split('\n');
  const enc=lineas[0].split(',').map(h=>h.replace(/"/g,'').trim().toLowerCase());
  return lineas.slice(1).map(linea=>{
    const vals=[]; let actual=''; let dentro=false;
    for(let c of linea){
      if(c==='"'){dentro=!dentro;}
      else if(c===','&&!dentro){vals.push(actual);actual='';}
      else{actual+=c;}
    }
    vals.push(actual);
    const obj={};
    enc.forEach((h,i)=>{ obj[h]=(vals[i]||'').replace(/"/g,'').trim(); });
    return obj;
  });
}

function renderLista(datos){
  const lista=document.getElementById('lista');
  if(datos.length===0){ lista.innerHTML=`<div style="text-align:center;padding:40px 20px;color:var(--texto2)"><div style="font-size:32px;margin-bottom:8px">📍</div><p style="font-size:13px">No hay reportes</p></div>`; return; }
  lista.innerHTML=datos.map((r,i)=>{
    const p=getPrioridad(r.prioridad);
    const est=getEstado(r);
    const lat=parseFloat(r.latitud), lng=parseFloat(r.longitud);
    const tieneCoords=!isNaN(lat)&&!isNaN(lng);
    const idxReal=reportes.indexOf(r);
    return `<div class="reporte-card ${p} ${est}" id="card-${idxReal}">
      <div class="card-top">
        <div class="card-tipo">${r.tipo||'Sin tipo'}</div>
        <div class="card-badges">
          <span class="card-prioridad ${p}">${r.prioridad||'Baja'}</span>
          <span class="card-estado ${est}">${est}</span>
        </div>
      </div>
      <div class="card-desc">${r.descripcion||'Sin descripción'}</div>
      ${tieneCoords?`<div class="card-coords">${lat.toFixed(4)}, ${lng.toFixed(4)}</div>`:''}
      <div class="card-actions">
        ${tieneCoords?`<button class="btn-resolver btn-ver" onclick="irA(${idxReal})">Ver en mapa</button>`:''}
        ${est==='pendiente'
          ?`<button class="btn-resolver btn-pendiente" onclick="cambiarEstado('${r.fecha}','Terminado',${idxReal})">✓ Marcar resuelto</button>`
          :`<button class="btn-resolver btn-terminado-act" onclick="cambiarEstado('${r.fecha}','Pendiente',${idxReal})">↺ Reabrir</button>`
        }
      </div>
    </div>`;
  }).join('');
}

function renderMapa(datos){
  markers.forEach(m=>mapa.removeLayer(m));
  markers=new Array(reportes.length).fill(null);
  const bounds=[];
  datos.forEach(r=>{
    const lat=parseFloat(r.latitud), lng=parseFloat(r.longitud);
    if(isNaN(lat)||isNaN(lng)) return;
    const p=getPrioridad(r.prioridad);
    const est=getEstado(r);
    const idxReal=reportes.indexOf(r);
    const marker=L.marker([lat,lng],{icon:crearIcono(p,est)});
    const color=est==='terminado'?'#4ac87a':getColor(p);
    marker.bindPopup(`
      <div class="popup-tipo">${r.tipo||'Sin tipo'}</div>
      <div class="popup-row"><strong>Descripción:</strong> ${r.descripcion||'—'}</div>
      <div class="popup-badges">
        <span class="popup-badge" style="background:${getColor(p)}22;color:${getColor(p)}">${r.prioridad||'Baja'}</span>
        <span class="popup-badge" style="background:${color}22;color:${color}">${est}</span>
      </div>
      <div class="popup-row"><strong>Coords:</strong> ${lat.toFixed(5)}, ${lng.toFixed(5)}</div>
      <div class="popup-actions">
        ${est==='pendiente'
          ?`<button class="popup-btn" style="background:#f0c84a22;color:#f0c84a;border:1px solid #f0c84a" onclick="cambiarEstado('${r.fecha}','Terminado',${idxReal});mapa.closePopup()">✓ Marcar resuelto</button>`
          :`<button class="popup-btn" style="background:#4ac87a22;color:#4ac87a;border:1px solid #4ac87a" onclick="cambiarEstado('${r.fecha}','Pendiente',${idxReal});mapa.closePopup()">↺ Reabrir</button>`
        }
      </div>
    `);
    marker.addTo(mapa);
    markers[idxReal]=marker;
    bounds.push([lat,lng]);
  });
  if(bounds.length>0) mapa.fitBounds(bounds,{padding:[40,40]});
}

function actualizarStats(datos){
  document.getElementById('cnt-alta').textContent=datos.filter(r=>getPrioridad(r.prioridad)==='alta').length;
  document.getElementById('cnt-media').textContent=datos.filter(r=>getPrioridad(r.prioridad)==='media').length;
  document.getElementById('cnt-baja').textContent=datos.filter(r=>getPrioridad(r.prioridad)==='baja').length;
  document.getElementById('cnt-terminado').textContent=datos.filter(r=>getEstado(r)==='terminado').length;
}

function aplicarFiltro(){
  let filtrados=reportes.filter(r=>r.tipo||r.descripcion);
  if(filtroActual==='pendiente') filtrados=filtrados.filter(r=>getEstado(r)==='pendiente');
  else if(filtroActual==='terminado') filtrados=filtrados.filter(r=>getEstado(r)==='terminado');
  else if(filtroActual==='Alta') filtrados=filtrados.filter(r=>getPrioridad(r.prioridad)==='alta');
  renderLista(filtrados);
  renderMapa(filtrados);
}

function filtrar(tipo,btn){
  filtroActual=tipo;
  document.querySelectorAll('.filtro-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  aplicarFiltro();
}

function irA(i){
  const r=reportes[i];
  const lat=parseFloat(r.latitud), lng=parseFloat(r.longitud);
  if(!isNaN(lat)&&!isNaN(lng)){ mapa.setView([lat,lng],16); markers[i]?.openPopup(); }
}

async function cargarDatos(){
  try{
    document.getElementById('btn-actualizar').textContent='↻ Cargando...';
    const res=await fetch(URL_CSV+'&t='+Date.now());
    const texto=await res.text();
    reportes=parsearCSV(texto);
    actualizarStats(reportes);
    aplicarFiltro();
  } catch(e){
    document.getElementById('lista').innerHTML=`<div style="text-align:center;padding:40px 20px;color:var(--texto2)"><div style="font-size:32px">⚠️</div><p style="font-size:13px;margin-top:8px">Error al cargar datos.<br>Verifica que el Sheets esté publicado.</p></div>`;
  } finally{
    document.getElementById('btn-actualizar').textContent='↻ Actualizar';
    document.getElementById('loading').style.display='none';
  }
}

cargarDatos();
</script>
</body>
</html>
